---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { SERIES_CONFIG, SERIES_ORDER } from '../consts/series';
import { getDayNumber, sortByDay } from '../utils/posts';
import { withBase } from '../utils/paths';

const allPosts = await getCollection('blog');
const totalPublished = allPosts.length;

const seriesGroups = SERIES_ORDER.map((key) => ({
	key,
	config: SERIES_CONFIG[key],
	posts: sortByDay(allPosts.filter((p) => p.data.series === key)),
}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin-bottom: 2.5rem;
				padding: 2rem 1.5rem;
				border-radius: 16px;
				background: linear-gradient(135deg, #f0fdfa 0%, #fff 55%, #f8fafc 100%);
				border: 1px solid #ccfbf1;
			}
			.hero h1 {
				margin: 0 0 0.5em;
				font-size: 1.85rem;
				font-weight: 700;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.hero-desc {
				margin: 0 0 1.25em;
				color: rgb(var(--gray-dark));
				line-height: 1.8;
				font-size: 0.975rem;
			}
			.progress-wrap {
				display: flex;
				flex-direction: column;
				gap: 0.45em;
			}
			.progress-label {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.progress-label strong {
				color: var(--accent-dark);
				font-weight: 600;
			}
			.progress-bar {
				height: 6px;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				overflow: hidden;
			}
			.progress-fill {
				height: 100%;
				border-radius: 999px;
				background: linear-gradient(90deg, var(--accent), #2dd4bf);
				transition: width 0.4s ease;
			}

			.series-overview {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-bottom: 2.5rem;
			}
			.overview-card {
				padding: 1.15rem 1.25rem;
				border-radius: 12px;
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
			}
			.overview-card:hover {
				text-decoration: none;
				transform: translateY(-2px);
				box-shadow: 0 4px 16px rgba(var(--gray), 18%);
			}
			.overview-card.is-llm {
				border-top: 3px solid var(--accent);
			}
			.overview-card.is-llm:hover {
				border-color: #5eead4;
			}
			.overview-card.is-agent {
				border-top: 3px solid #6366f1;
			}
			.overview-card.is-agent:hover {
				border-color: #a5b4fc;
			}
			.overview-meta {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 0.35em;
			}
			.overview-title {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.overview-card.is-agent .overview-title {
				color: #4338ca;
			}
			.overview-count {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.overview-desc {
				margin: 0 0 0.6em;
				font-size: 0.85rem;
				line-height: 1.6;
				color: rgb(var(--gray-dark));
			}
			.overview-range {
				font-size: 0.75rem;
				font-weight: 500;
				color: rgb(var(--gray));
				letter-spacing: 0.02em;
			}

			.series-section {
				margin-bottom: 2.75rem;
			}
			.series-section:last-child {
				margin-bottom: 0;
			}
			.series-header {
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
				padding-bottom: 0.65rem;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.series-section.is-llm .series-header {
				border-bottom-color: #99f6e4;
			}
			.series-section.is-agent .series-header {
				border-bottom-color: #c7d2fe;
			}
			.series-header h2 {
				margin: 0;
				font-size: 1.25rem;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.series-section.is-agent .series-header h2 {
				color: #4338ca;
			}
			.series-subtitle {
				margin: 0.15em 0 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.series-count {
				flex-shrink: 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}

			.post-grid {
				display: grid;
				gap: 0.65rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				display: grid;
				grid-template-columns: auto 1fr auto;
				gap: 0.85rem 1rem;
				align-items: start;
				padding: 0.9rem 1.1rem;
				border-radius: 10px;
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.post-card:hover {
				text-decoration: none;
				box-shadow: 0 2px 10px rgba(var(--gray), 12%);
			}
			.series-section.is-llm .post-card:hover {
				border-color: #5eead4;
			}
			.series-section.is-agent .post-card:hover {
				border-color: #a5b4fc;
			}
			.day-badge {
				display: flex;
				align-items: center;
				justify-content: center;
				min-width: 2.6rem;
				height: 2.6rem;
				border-radius: 8px;
				font-size: 0.75rem;
				font-weight: 700;
				line-height: 1.1;
				text-align: center;
			}
			.series-section.is-llm .day-badge {
				background: var(--accent-light);
				color: var(--accent-dark);
			}
			.series-section.is-agent .day-badge {
				background: #eef2ff;
				color: #4338ca;
			}
			.post-body {
				min-width: 0;
			}
			.post-title {
				margin: 0 0 0.2em;
				font-size: 1rem;
				font-weight: 600;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}
			.post-card:hover .post-title {
				color: var(--accent);
			}
			.series-section.is-agent .post-card:hover .post-title {
				color: #4338ca;
			}
			.post-desc {
				margin: 0;
				font-size: 0.825rem;
				line-height: 1.55;
				color: rgb(var(--gray));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-date {
				margin: 0;
				flex-shrink: 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
				white-space: nowrap;
				padding-top: 0.15em;
			}
			.empty {
				color: rgb(var(--gray));
				font-style: italic;
				font-size: 0.9rem;
			}

			@media (max-width: 640px) {
				.hero {
					padding: 1.5rem 1.1rem;
				}
				.hero h1 {
					font-size: 1.5rem;
				}
				.series-overview {
					grid-template-columns: 1fr;
				}
				.post-card {
					grid-template-columns: auto 1fr;
				}
				.post-date {
					grid-column: 2;
					padding-top: 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p class="hero-desc">
					{SITE_DESCRIPTION} 本系列计划用 100 篇文章，覆盖大模型从基础架构到工程实践的核心知识点，每篇聚焦一个概念，由浅入深。
				</p>
				<div class="progress-wrap">
					<div class="progress-label">
						<span>学习进度</span>
						<strong>{totalPublished} / 100 篇</strong>
					</div>
					<div class="progress-bar" role="progressbar" aria-valuenow={totalPublished} aria-valuemin={0} aria-valuemax={100}>
						<div class="progress-fill" style={`width: ${totalPublished}%`}></div>
					</div>
				</div>
			</section>

			<section class="series-overview" aria-label="系列概览">
				{
					seriesGroups.map(({ key, config, posts }) => (
						<a href={`#series-${key}`} class={`overview-card ${key === 'llm-fundamentals' ? 'is-llm' : 'is-agent'}`}>
							<div class="overview-meta">
								<h3 class="overview-title">{config.title}</h3>
								<span class="overview-count">{posts.length} 篇已发布</span>
							</div>
							<p class="overview-desc">{config.description}</p>
							<span class="overview-range">{config.dayRange}</span>
						</a>
					))
				}
			</section>

			{
				seriesGroups.map(({ key, config, posts }) => (
					<section
						id={`series-${key}`}
						class={`series-section ${key === 'llm-fundamentals' ? 'is-llm' : 'is-agent'}`}
						aria-labelledby={`heading-${key}`}
					>
						<div class="series-header">
							<div>
								<h2 id={`heading-${key}`}>{config.title}</h2>
								<p class="series-subtitle">{config.subtitle} · {config.dayRange}</p>
							</div>
							<span class="series-count">{posts.length} 篇</span>
						</div>
						{
							posts.length > 0 ? (
								<ul class="post-grid">
									{posts.map((post) => (
										<li>
											<a href={withBase(`/blog/${post.id}/`)} class="post-card">
												<span class="day-badge">Day<br />{getDayNumber(post.id)}</span>
												<div class="post-body">
													<h3 class="post-title">{post.data.title}</h3>
													<p class="post-desc">{post.data.description}</p>
												</div>
												<p class="post-date">
													<FormattedDate date={post.data.pubDate} />
												</p>
											</a>
										</li>
									))}
								</ul>
							) : (
								<p class="empty">该系列暂无文章，敬请期待。</p>
							)
						}
					</section>
				))
			}
		</main>
		<Footer />
	</body>
</html>
